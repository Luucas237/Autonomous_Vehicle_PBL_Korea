<?xml version="1.0" ?>
<robot name="ack" xmlns:xacro="http://ros.org/wiki/xacro">

  <gazebo>
    <plugin filename="ignition-gazebo-diff-drive-system" name="ignition::gazebo::systems::DiffDrive">
      <left_joint>wheel_lf_Joint</left_joint>
      <left_joint>wheel_lb_Joint</left_joint>
      <right_joint>wheel_rf_Joint</right_joint>
      <right_joint>wheel_rb_Joint</right_joint>
      <wheel_separation>0.14</wheel_separation>
      <wheel_radius>0.033</wheel_radius>
      <odom_publish_frequency>50</odom_publish_frequency>
      <topic>cmd_vel</topic>
    </plugin>
  </gazebo>

  <material name="black"><color rgba="0.1 0.1 0.1 1"/></material>
  <material name="blue"><color rgba="0.0 0.4 1.0 1"/></material>

  <link name="base_link">
    <inertial>
      <origin rpy="0 0 0" xyz="-0.001 0 -0.006"/>
      <mass value="0.5"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
    <visual>
      <geometry><box size="0.2 0.12 0.05"/></geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <geometry><box size="0.2 0.12 0.05"/></geometry>
    </collision>
  </link>

  <link name="base_footprint"/>
  <joint name="base_footprint_to_base_link" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.07" rpy="0 0 0"/>
  </joint>

  <xacro:macro name="wheel" params="prefix x y">
    <link name="wheel_${prefix}_Link">
      <visual>
        <origin rpy="1.5708 0 0" xyz="0 0 0"/>
        <geometry><cylinder radius="0.033" length="0.02"/></geometry>
        <material name="black"/>
      </visual>
      <collision>
        <origin rpy="1.5708 0 0" xyz="0 0 0"/>
        <geometry><cylinder radius="0.033" length="0.02"/></geometry>
      </collision>
      <inertial>
        <mass value="0.05"/>
        <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
      </inertial>
    </link>
    <joint name="wheel_${prefix}_Joint" type="continuous">
      <origin rpy="0 0 0" xyz="${x} ${y} -0.028"/>
      <parent link="base_link"/>
      <child link="wheel_${prefix}_Link"/>
      <axis xyz="0 1 0"/>
    </joint>
  </xacro:macro>

  <xacro:wheel prefix="lf" x="0.07" y="0.07"/>
  <xacro:wheel prefix="rf" x="0.07" y="-0.07"/>
  <xacro:wheel prefix="lb" x="-0.07" y="0.07"/>
  <xacro:wheel prefix="rb" x="-0.07" y="-0.07"/>

  <link name="depth_cam">
    <visual>
      <geometry><box size="0.02 0.05 0.05"/></geometry>
      <material name="red"/>
    </visual>
    <inertial>
      <mass value="0.01"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>
  
  <joint name="cam_Joint" type="fixed">
    <origin rpy="0 0 0" xyz="0.1 0 0.04"/>
    <parent link="base_link"/>
    <child link="depth_cam"/>
  </joint>

  <gazebo reference="depth_cam">
    <sensor name="front_camera" type="camera">
      <camera>
        <horizontal_fov>1.396</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.02</near>
          <far>100.0</far>
        </clip>
      </camera>
      <always_on>1</always_on>
      <update_rate>30</update_rate>
      <visualize>true</visualize>
      <topic>/camera/image_raw</topic>
    </sensor>
  </gazebo>

</robot>